# Local demo JWT values.
# Generate matching values with: npm run demo:key
DEMO_PRIVATE_KEY="replace-with-generated-pkcs8-key"

# Also configure this value in Convex with:
# npx convex env set DEMO_JWKS "replace-with-generated-jwks-data-url"
DEMO_JWKS="replace-with-generated-jwks-data-url"

# Optional comma-separated web origins allowed to call Better Auth routes.
# Local Flutter web origins on localhost/127.0.0.1 are accepted automatically.
BETTER_AUTH_TRUSTED_ORIGINS=https://your-web-demo.example
